<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.MouthGuard" parent="Theme.MaterialComponents.Light.NoActionBar">
        <item name="colorPrimary">@color/ink</item>
        <item name="colorPrimaryVariant">@color/ink</item>
        <item name="colorOnPrimary">@color/text_white</item>
        <item name="colorSecondary">@color/pastel_yellow</item>
        <item name="colorSecondaryVariant">@color/pastel_yellow</item>
        <item name="colorOnSecondary">@color/ink</item>
        <item name="android:windowBackground">@color/bg_main</item>
        <item name="android:statusBarColor">@color/bg_main</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:navigationBarColor">@color/bg_main</item>
        <item name="android:windowLightNavigationBar" tools:targetApi="27">true</item>
        <item name="android:textViewStyle">@style/AppText</item>
        <item name="android:fontFamily">@font/zen_maru_gothic</item>
        <item name="fontFamily">@font/zen_maru_gothic</item>
    </style>

    <style name="AppText" parent="@android:style/Widget.TextView">
        <item name="android:fontFamily">@font/zen_maru_gothic</item>
        <item name="android:textColor">@color/ink</item>
        <item name="android:includeFontPadding">false</item>
    </style>
</resources>
