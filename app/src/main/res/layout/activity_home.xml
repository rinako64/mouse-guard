<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/kids_bg"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="24dp">

        <!-- かわいいキャラクター的な絵文字 -->
        <TextView
            android:id="@+id/tvIcon"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/app_icon_emoji"
            android:textSize="80sp"
            android:textAlignment="center"
            android:layout_marginTop="32dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- アプリ名 -->
        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="@string/app_name"
            android:textSize="32sp"
            android:textStyle="bold"
            android:textColor="@color/kids_pink"
            android:textAlignment="center"
            android:fontFamily="sans-serif-medium"
            android:layout_marginTop="8dp"
            app:layout_constraintTop_toBottomOf="@id/tvIcon"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- 説明 -->
        <TextView
            android:id="@+id/tvDescription"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/app_description"
            android:textSize="16sp"
            android:textColor="@color/kids_text_dark"
            android:textAlignment="center"
            android:lineSpacingMultiplier="1.6"
            app:layout_constraintTop_toBottomOf="@id/tvTitle"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- スタートボタン -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnStart"
            style="@style/KidsButton.Start"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:text="@string/btn_start_monitoring"
            android:elevation="8dp"
            app:icon="@android:drawable/ic_media_play"
            app:iconGravity="textStart"
            app:layout_constraintTop_toBottomOf="@id/tvDescription"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- ストップボタン -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnStop"
            style="@style/KidsButton.Stop"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:text="@string/btn_stop_monitoring"
            android:elevation="8dp"
            app:icon="@android:drawable/ic_media_pause"
            app:iconGravity="textStart"
            app:layout_constraintTop_toBottomOf="@id/btnStart"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- 使い方カード -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardInstructions"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:layout_marginBottom="24dp"
            app:cardCornerRadius="20dp"
            app:cardBackgroundColor="@color/kids_white"
            app:cardElevation="4dp"
            app:layout_constraintTop_toBottomOf="@id/btnStop"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toBottomOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/how_to_use_title"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/kids_blue" />

                <TextView
                    android:id="@+id/tvInstructions"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="@string/instructions"
                    android:textSize="15sp"
                    android:textColor="@color/kids_text_dark"
                    android:lineSpacingMultiplier="1.8" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

    </androidx.constraintlayout.widget.ConstraintLayout>

</ScrollView>
