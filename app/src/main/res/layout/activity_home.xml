<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_main">

    <!-- ヘッダー -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="20dp"
        android:paddingTop="12dp"
        android:paddingBottom="8dp">

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/mascot_octopus"
            android:contentDescription="マスコット" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="MouseGuard"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="@color/primary_pink" />
    </LinearLayout>

    <!-- スクロール可能コンテンツ -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true"
        android:clipToPadding="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="24dp"
            android:paddingBottom="16dp">

            <!-- キャラクター -->
            <ImageView
                android:layout_width="160dp"
                android:layout_height="160dp"
                android:layout_gravity="center_horizontal"
                android:src="@drawable/mascot_octopus"
                android:contentDescription="マスコット"
                android:layout_marginTop="16dp" />

            <!-- アプリ名 -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="MouseGuard"
                android:textSize="30sp"
                android:textStyle="bold"
                android:textColor="@color/primary_pink"
                android:textAlignment="center"
                android:layout_marginTop="4dp" />

            <!-- サブタイトル -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/app_subtitle"
                android:textSize="15sp"
                android:textColor="@color/text_dark"
                android:textAlignment="center"
                android:layout_marginTop="4dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/app_subtitle2"
                android:textSize="12sp"
                android:textColor="@color/text_gray"
                android:textAlignment="center"
                android:layout_marginTop="2dp" />

            <!-- 監視スタートボタン -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp">

                <LinearLayout
                    android:id="@+id/btnStart"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_btn_start"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:paddingVertical="24dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:elevation="4dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🎥"
                        android:textSize="28sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/btn_start_monitoring"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_white"
                        android:layout_marginTop="4dp" />
                </LinearLayout>
            </FrameLayout>

            <!-- 監視ストップボタン -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp">

                <LinearLayout
                    android:id="@+id/btnStop"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_btn_stop"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:paddingVertical="24dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:elevation="4dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="⏹️"
                        android:textSize="28sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/btn_stop_monitoring"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_white"
                        android:layout_marginTop="4dp" />
                </LinearLayout>
            </FrameLayout>

            <!-- 使い方カード -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_card"
                android:orientation="vertical"
                android:padding="20dp"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="8dp"
                android:elevation="2dp">

                <!-- タイトル行 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="❓"
                        android:textSize="20sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/how_to_use_title"
                        android:textSize="17sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_dark"
                        android:layout_marginStart="8dp" />
                </LinearLayout>

                <!-- ステップ1 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="14dp">

                    <TextView
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:background="@drawable/bg_step_circle"
                        android:text="1"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="@color/step_circle_text"
                        android:gravity="center" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/step_1"
                        android:textSize="14sp"
                        android:textColor="@color/text_dark"
                        android:layout_marginStart="12dp" />
                </LinearLayout>

                <!-- ステップ2 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="14dp">

                    <TextView
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:background="@drawable/bg_step_circle"
                        android:text="2"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="@color/step_circle_text"
                        android:gravity="center" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/step_2"
                        android:textSize="14sp"
                        android:textColor="@color/text_dark"
                        android:layout_marginStart="12dp" />
                </LinearLayout>

                <!-- ステップ3 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:background="@drawable/bg_step_circle"
                        android:text="3"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="@color/step_circle_text"
                        android:gravity="center" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/step_3"
                        android:textSize="14sp"
                        android:textColor="@color/text_dark"
                        android:layout_marginStart="12dp" />
                </LinearLayout>
            </LinearLayout>

        </LinearLayout>
    </ScrollView>


</LinearLayout>
