<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/overlay_bg">

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="32dp">

        <!-- ぽかろ（マスコット） -->
        <ImageView
            android:layout_width="180dp"
            android:layout_height="wrap_content"
            android:adjustViewBounds="true"
            android:src="@drawable/mascot_pokaro"
            android:contentDescription="ぽかろ" />

        <TextView
            android:id="@+id/tvOverlayMessage"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/mouth_open_warning"
            android:textSize="40sp"
            android:textColor="@color/pastel_yellow"
            android:textStyle="bold"
            android:textAlignment="center"
            android:fontFamily="@font/zen_maru_gothic"
            android:lineSpacingMultiplier="1.3" />

    </LinearLayout>

</FrameLayout>
